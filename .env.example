# =============================================================================
# Application
# =============================================================================
PORT=3000
NODE_ENV=development

# =============================================================================
# Database (PostgreSQL)
# Must match the values in docker-compose.yml
# =============================================================================
POSTGRES_USER=booking_user
POSTGRES_PASSWORD=booking_pass
POSTGRES_DB=booking_db

# Prisma uses this to connect to PostgreSQL.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL="postgresql://booking_user:booking_pass@localhost:5432/booking_db?schema=public"

# =============================================================================
# JWT Authentication
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =============================================================================
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_STRONG_RANDOM_SECRET
JWT_REFRESH_EXPIRES_IN=30d
