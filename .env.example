# =============================================================================
# Application
# =============================================================================
PORT=3000
NODE_ENV=development

# =============================================================================
# Database (PostgreSQL)
# Values here must match docker-compose.yml.
# Change POSTGRES_PASSWORD to something strong before running in any environment.
# =============================================================================
POSTGRES_USER=booking_user
POSTGRES_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD
POSTGRES_DB=booking_db

# Prisma uses this URL to connect to PostgreSQL.
# Build it from the values above: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL="postgresql://REPLACE_WITH_POSTGRES_USER:REPLACE_WITH_POSTGRES_PASSWORD@localhost:5432/REPLACE_WITH_POSTGRES_DB?schema=public"

# =============================================================================
# JWT Authentication
# Generate strong secrets using:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =============================================================================
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=7d
